### 1. WebGL/WebGPU Scene Vessel Setup (vanilla JS class)
```javascript
import * as THREE from 'three';
import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';

export class CreativeVessel {
  constructor(canvasElement) {
    this.canvas = canvasElement;
    this.width = window.innerWidth;
    this.height = window.innerHeight;
    
    // Scene setup
    this.scene = new THREE.Scene();
    this.scene.background = new THREE.Color(0x0a0a0a);
    
    // Camera setup
    this.camera = new THREE.PerspectiveCamera(45, this.width / this.height, 0.1, 100);
    this.camera.position.set(0, 0, 5);
    
    // Renderer initialization
    this.renderer = new THREE.WebGLRenderer({
      canvas: this.canvas,
      antialias: true,
      alpha: false,
      powerPreference: "high-performance"
    });
    this.renderer.setSize(this.width, this.height);
    this.renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    
    // Orbit controls
    this.controls = new OrbitControls(this.camera, this.canvas);
    this.controls.enableDamping = true;
    this.controls.dampingFactor = 0.05;
    
    // Clock setup
    this.clock = new THREE.Clock();
    
    this.initEvents();
    this.tick();
  }
  
  initEvents() {
    window.addEventListener('resize', () => {
      this.width = window.innerWidth;
      this.height = window.innerHeight;
      
      this.camera.aspect = this.width / this.height;
      this.camera.updateProjectionMatrix();
      
      this.renderer.setSize(this.width, this.height);
      this.renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    });
  }
  
  tick() {
    const elapsedTime = this.clock.getElapsedTime();
    
    // Smooth control updates
    this.controls.update();
    
    // Dispatch custom update events for dynamic elements
    const updateEvent = new CustomEvent('canvas-tick', { detail: { time: elapsedTime } });
    window.dispatchEvent(updateEvent);
    
    this.renderer.render(this.scene, this.camera);
    
    requestAnimationFrame(() => this.tick());
  }
}
```

### 2. Custom GLSL Displacement Shader (Vertex + Fragment shaders)
```glsl
// Vertex Shader (displacement_vertex.glsl)
uniform float uTime;
uniform vec2 uCursorVelocity;
varying vec2 vUv;
varying float vNoise;

// Simplex 3D Noise by Ashima Arts
vec4 permute(vec4 x){return mod(((x*34.0)+1.0)*x, 289.0);}
vec4 taylorInvSqrt(vec4 r){return 1.79284291400159 - 0.85373472095314 * r;}

float snoise(vec3 v){
  const vec2  C = vec2(1.0/6.0, 1.0/3.0) ;
  const vec4  D = vec4(0.0, 0.5, 1.0, 2.0);

  vec3 i  = floor(v + dot(v, C.yyy) );
  vec3 x0 =   v - i + dot(i, C.xxx) ;

  vec3 g = step(x0.yzx, x0.xyz);
  vec3 l = 1.0 - g;
  vec3 i1 = min( g.xyz, l.zxy );
  vec3 i2 = max( g.xyz, l.zxy );

  vec3 x1 = x0 - i1 + 1.0 * C.xxx;
  vec3 x2 = x0 - i2 + 2.0 * C.xxx;
  vec3 x3 = x0 - 1.0 + 3.0 * C.xxx;

  i = mod(i, 289.0 );
  vec4 p = permute( permute( permute(
             i.z + vec4(0.0, i1.z, i2.z, 1.0 ))
           + i.y + vec4(0.0, i1.y, i2.y, 1.0 ))
           + i.x + vec4(0.0, i1.x, i2.x, 1.0 ));

  float n_ = 0.142857142857; // 1.0/7.0
  vec3  ns = n_ * D.wyz - D.xzx;

  vec4 j = p - 49.0 * floor(p * ns.z *ns.z);  //  mod(p,7*7)

  vec4 x_ = floor(j * ns.z);
  vec4 y_ = floor(j - 7.0 * x_ );    // mod(j,N)

  vec4 x = x_ *ns.x + ns.yyyy;
  vec4 y = y_ *ns.x + ns.yyyy;
  vec4 h = 1.0 - abs(x) - abs(y);

  vec4 b0 = vec4( x.xy, y.xy );
  vec4 b1 = vec4( x.zw, y.zw );

  vec4 s0 = floor(b0)*2.0 + 1.0;
  vec4 s1 = floor(b1)*2.0 + 1.0;
  vec4 sh = -step(h, vec4(0.0));

  vec4 a0 = b0.xzyw + s0.xzyw*sh.xxyy ;
  vec4 a1 = b1.xzyw + s1.xzyw*sh.zzww ;

  vec3 p0 = vec3(a0.xy,h.x);
  vec3 p1 = vec3(a0.zw,h.y);
  vec3 p2 = vec3(a1.xy,h.z);
  vec3 p3 = vec3(a1.zw,h.w);

  vec4 norm = taylorInvSqrt(vec4(dot(p0,p0), dot(p1,p1), dot(p2, p2), dot(p3,p3)));
  p0 *= norm.x;
  p1 *= norm.y;
  p2 *= norm.z;
  p3 *= norm.w;

  vec4 m = max(0.6 - vec4(dot(x0,x0), dot(x1,x1), dot(x2,x2), dot(x3,x3)), 0.0);
  m = m * m;
  return 42.0 * dot( m*m, vec4( dot(p0,x0), dot(p1,x1),
                                dot(p2,x2), dot(p3,x3) ) );
}

void main() {
  vUv = uv;
  
  // Calculate noise offset based on time and cursor velocity
  vec3 posOffset = vec3(position.xy * 2.0, uTime * 0.5);
  vNoise = snoise(posOffset);
  
  // Displace along Z axis based on noise + velocity intensity
  float velocityIntensity = length(uCursorVelocity);
  vec3 newPosition = position;
  newPosition.z += vNoise * (0.15 + velocityIntensity * 0.5);
  
  gl_Position = projectionMatrix * modelViewMatrix * vec4(newPosition, 1.0);
}
```

```glsl
// Fragment Shader (displacement_fragment.glsl)
uniform sampler2D uTexture;
uniform float uTime;
varying vec2 vUv;
varying float vNoise;

void main() {
  // Use noise to displace UV coordinates
  vec2 displacedUv = vUv;
  displacedUv.x += vNoise * 0.03;
  displacedUv.y += vNoise * 0.03;
  
  vec4 texColor = texture2D(uTexture, displacedUv);
  
  // Subtle chromatic aberration
  vec4 redChannel = texture2D(uTexture, displacedUv + vec2(vNoise * 0.005, 0.0));
  vec4 blueChannel = texture2D(uTexture, displacedUv - vec2(vNoise * 0.005, 0.0));
  
  vec4 finalColor = vec4(redChannel.r, texColor.g, blueChannel.b, 1.0);
  
  // Add dark texture overlay
  float vignette = vUv.x * (1.0 - vUv.x) * vUv.y * (1.0 - vUv.y);
  vignette = clamp(pow(vignette * 15.0, 0.25), 0.0, 1.0);
  
  gl_FragColor = finalColor * vignette;
}
