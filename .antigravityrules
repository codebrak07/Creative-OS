### 3. SoundManager Class (Howler.js setup)
```javascript
import { Howl, Howler } from 'howler';

export class SoundManager {
  constructor() {
    this.muted = true;
    this.sounds = new Map();
    
    // Ambient sound setup
    this.ambientSound = null;
    
    this.init();
  }
  
  init() {
    // Configure global volume limits
    Howler.volume(0.8);
    
    // Interaction sounds register
    this.sounds.set('click', new Howl({
      src: ['/audio/click.mp3', '/audio/click.ogg'],
      volume: 0.12,
      pool: 10
    }));
    
    this.sounds.set('transition', new Howl({
      src: ['/audio/transition.mp3'],
      volume: 0.25,
      pool: 2
    }));
  }
  
  playAmbient(src) {
    if (this.ambientSound) {
      this.ambientSound.stop();
    }
    
    this.ambientSound = new Howl({
      src: [src],
      loop: true,
      volume: 0.0, // starts at 0 for smooth fade-in
      html5: true  // stream large assets directly
    });
    
    if (!this.muted) {
      this.ambientSound.play();
      this.ambientSound.fade(0, 0.3, 2000);
    }
  }
  
  playTick() {
    if (this.muted) return;
    const clickSound = this.sounds.get('click');
    if (clickSound) {
      // Slight pitch variation to prevent audio fatigue
      clickSound.rate(0.95 + Math.random() * 0.1);
      clickSound.play();
    }
  }
  
  playSweep() {
    if (this.muted) return;
    const sweepSound = this.sounds.get('transition');
    if (sweepSound) {
      sweepSound.play();
    }
  }
  
  toggleMute(btnElement) {
    this.muted = !this.muted;
    Howler.mute(this.muted);
    
    if (!this.muted && this.ambientSound && !this.ambientSound.playing()) {
      this.ambientSound.play();
      this.ambientSound.fade(0, 0.3, 1000);
    }
    
    // Update button display properties
    if (btnElement) {
      btnElement.classList.toggle('is-muted', this.muted);
      btnElement.setAttribute('aria-label', this.muted ? 'Unmute' : 'Mute');
    }
  }
}
