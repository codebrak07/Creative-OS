## 14. CODE TEMPLATES & WORKSPACE RECIPES

To ensure 100% capability inside the Cursor agent, study the following concrete code architectures for each motion pattern.

### Recipe 1: RXK Text Echo Animation (GSAP)
```javascript
export function initRxkEchoText(elementSelector) {
  const elements = document.querySelectorAll(elementSelector);
  
  elements.forEach((el) => {
    const text = el.textContent;
    el.setAttribute('data-text', text);
    el.classList.add('echo-text');
    
    // Create GSAP Hover timeline
    const tl = gsap.timeline({ paused: true });
    
    // Target pseudoelement offset via custom CSS variable
    tl.to(el, {
      '--echo-offset-x': '8px',
      '--echo-offset-y': '4px',
      duration: 0.6,
      ease: 'power3.out'
    });
    
    el.addEventListener('mouseenter', () => tl.play());
    el.addEventListener('mouseleave', () => tl.reverse());
  });
}
```

### Recipe 2: Velocity-Based Cursor Setup
```javascript
export class VelocityCursor {
  constructor(cursorElement) {
    this.el = cursorElement;
    this.pos = { x: 0, y: 0 };
    this.target = { x: 0, y: 0 };
    this.last = { x: 0, y: 0 };
    this.vel = 0;
    
    this.init();
  }
  
  init() {
    window.addEventListener('mousemove', (e) => {
      this.target.x = e.clientX;
      this.target.y = e.clientY;
    });
    
    this.tick();
  }
  
  tick() {
    // Linear interpolation loop
    this.pos.x += (this.target.x - this.pos.x) * 0.1;
    this.pos.y += (this.target.y - this.pos.y) * 0.1;
    
    // Calculate velocity
    const dx = this.pos.x - this.last.x;
    const dy = this.pos.y - this.last.y;
    const speed = Math.sqrt(dx * dx + dy * dy);
    
    // Lag scale distortion
    const intensity = Math.min(speed / 50, 1);
    const scale = 1 + intensity * 0.8;
    
    // Apply GSAP updates
    gsap.set(this.el, {
      x: this.pos.x,
      y: this.pos.y,
      scaleX: scale,
      scaleY: 1 / scale
    });
    
    this.last.x = this.pos.x;
    this.last.y = this.pos.y;
    
    requestAnimationFrame(() => this.tick());
  }
}
```

### Recipe 3: Designed Preloader Screen (Vite)
```javascript
export function initPreloader(onComplete) {
  const loadScreen = document.querySelector('.load-screen');
  const counter = document.querySelector('.load-counter');
  
  let progress = { value: 0 };
  
  gsap.to(progress, {
    value: 100,
    duration: 3,
    ease: 'power2.out',
    onUpdate: () => {
      counter.textContent = String(Math.floor(progress.value)).padStart(3, '0');
    },
    onComplete: () => {
      // Preloader exit timeline
      const exitTl = gsap.timeline({
        onComplete: () => {
          loadScreen.remove();
          if (onComplete) onComplete();
        }
      });
      
      exitTl.to(loadScreen, {
        opacity: 0,
        duration: 0.8,
        ease: 'power3.inOut'
      });
    }
  });
}
```

### Recipe 4: Three.js Custom Shader Integration
```javascript
import * as THREE from 'three';

export function createShaderPlane(textureUrl) {
  const loader = new THREE.TextureLoader();
  const texture = loader.load(textureUrl);
  
  const geometry = new THREE.PlaneGeometry(2, 2, 32, 32);
  const material = new THREE.ShaderMaterial({
    uniforms: {
      uTexture: { value: texture },
      uTime: { value: 0 },
      uCursorVelocity: { value: new THREE.Vector2(0, 0) }
    },
    vertexShader: `
      uniform float uTime;
      uniform vec2 uCursorVelocity;
      varying vec2 vUv;
      
      void main() {
        vUv = uv;
        vec3 pos = position;
        float dist = length(uCursorVelocity);
        pos.z += sin(uv.x * 10.0 + uTime) * (0.05 + dist * 0.2);
        gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
      }
    `,
    fragmentShader: `
      uniform sampler2D uTexture;
      varying vec2 vUv;
      
      void main() {
        vec4 color = texture2D(uTexture, vUv);
        gl_FragColor = color;
      }
    `
  });
  
  return new THREE.Mesh(geometry, material);
}
```

### Recipe 5: Scroll-Triggered HSL Shift
```javascript
export function initScrollColorShift(containerElement) {
  const sections = [
    { hue: 220, sat: 12, light: 6 },
    { hue: 24,  sat: 15, light: 8 },
    { hue: 200, sat: 20, light: 7 }
  ];
  
  const items = containerElement.querySelectorAll('.color-section');
  
  items.forEach((item, index) => {
    if (index >= sections.length - 1) return;
    
    const nextSection = sections[index + 1];
    const currentSection = sections[index];
    
    gsap.timeline({
      scrollTrigger: {
        trigger: item,
        start: 'top top',
        end: 'bottom top',
        scrub: true,
        onUpdate: (self) => {
          const progress = self.progress;
          const h = gsap.utils.interpolate(currentSection.hue, nextSection.hue, progress);
          const s = gsap.utils.interpolate(currentSection.sat, nextSection.sat, progress);
          const l = gsap.utils.interpolate(currentSection.light, nextSection.light, progress);
          
          document.documentElement.style.setProperty(
            '--color-canvas',
            `hsl(${h}, ${s}%, ${l}%)`
          );
        }
      }
    });
  });
}
```

